# Configuration pour Air Algérie Issue Tracker Platform
# Copiez ce fichier vers .env et ajustez les valeurs selon votre environnement

# === BACKEND CONFIGURATION ===
# Port du serveur backend
SERVER_PORT=6969

# Base de données PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=issue_tracker_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_URL=jdbc:postgresql://${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Sécurité JWT
JWT_SECRET_KEY=564DDFE8C843709F13421E26F9456EAA3D5B1D7E053794BCF8560DB433566531
JWT_EXPIRATION_TIME=86400000

# === AI SERVICES CONFIGURATION ===
# Service de chatbot Rasa
CHATBOT_SERVICE_URL=http://localhost:5001
CLASSIFICATION_SERVICE_URL=http://localhost:5001

# Service de détection de doublons (optionnel)
DUPLICATE_SERVICE_URL=http://localhost:5000

# === FRONTEND CONFIGURATION ===
# URL de l'API backend pour le frontend
VITE_API_URL=http://localhost:6969

# === EMAIL CONFIGURATION (optionnel) ===
# Configuration SMTP pour les notifications
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true

# === CORS CONFIGURATION ===
# Origines autorisées pour CORS (séparées par des virgules)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000,http://frontend:80

# === FILE UPLOAD CONFIGURATION ===
# Dossier d'upload pour les captures d'écran
UPLOAD_PATH=uploads/screenshots
MAX_FILE_SIZE=10485760

# === MONITORING & LOGGING ===
# Niveau de logging
LOGGING_LEVEL=INFO
SPRING_PROFILES_ACTIVE=development

# === AIR ALGÉRIE SPECIFIC CONFIGURATION ===
# Paramètres spécifiques à Air Algérie
COMPANY_NAME=Air Algérie
COMPANY_DOMAIN=airalgerie.dz
DEFAULT_USER_ROLE=USER
ADMIN_EMAIL=admin@airalgerie.dz

# Chatbot configuration
CHATBOT_WELCOME_MESSAGE=Bonjour! Je suis l'assistant virtuel d'Air Algérie. Comment puis-je vous aider?
CHATBOT_FALLBACK_MESSAGE=Désolé, je n'ai pas compris. Pouvez-vous reformuler votre demande?

# === PRODUCTION SETTINGS ===
# Variables pour le déploiement en production
NODE_ENV=production
FLASK_ENV=production

# SSL/TLS (pour production)
SSL_ENABLED=false
SSL_KEY_STORE=
SSL_KEY_STORE_PASSWORD=
SSL_KEY_ALIAS=