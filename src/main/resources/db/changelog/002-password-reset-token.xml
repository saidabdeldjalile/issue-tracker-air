<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <!-- ==================== PASSWORD_RESET_TOKEN ==================== -->
    <changeSet id="015-create-password-reset-token" author="liquibase">
        <createTable tableName="password_reset_token">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="token" type="VARCHAR(255)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="user_id" type="INTEGER">
                <constraints nullable="false"/>
            </column>
            <column name="expires_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="used" type="BOOLEAN" defaultValueBoolean="false"/>
            <column name="used_at" type="TIMESTAMP"/>
        </createTable>

        <addForeignKeyConstraint
                baseTableName="password_reset_token"
                baseColumnNames="user_id"
                constraintName="fk_token_user"
                referencedTableName="_user"
                referencedColumnNames="id"/>

        <createIndex indexName="idx_token_token" tableName="password_reset_token">
            <column name="token"/>
        </createIndex>

        <createIndex indexName="idx_token_user" tableName="password_reset_token">
            <column name="user_id"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>