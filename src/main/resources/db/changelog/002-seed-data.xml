    <!-- ==================== SEED FAQ SAMPLE ==================== -->
    <changeSet id="004-seed-faq" author="liquibase">
        <insert tableName="faq">
            <column name="id" valueNumeric="1"/>
            <column name="question" value="Comment soumettre une demande d'absence ?"/>
            <column name="answer" value="Rendez-vous sur le portail interne, section 'Congés', et remplissez le formulaire de demande d'absence. Votre manager recevra une notification pour approbation."/>
            <column name="category" value="RH"/>
            <column name="department_id" valueNumeric="2"/>
            <column name="active" valueBoolean="true"/>
            <column name="view_count" valueNumeric="0"/>
        </insert>
        <insert tableName="faq">
            <column name="id" valueNumeric="2"/>
            <column name="question" value="Comment réinitialiser mon mot de passe ?"/>
            <column name="answer" value="Cliquez sur 'Mot de passe oublié' sur la page de connexion. Un email de réinitialisation sera envoyé à votre adresse professionnelle."/>
            <column name="category" value="Sécurité"/>
            <column name="department_id" valueNumeric="1"/>
            <column name="active" valueBoolean="true"/>
            <column name="view_count" valueNumeric="0"/>
        </insert>
    </changeSet>

